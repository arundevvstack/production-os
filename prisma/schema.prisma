generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ApiKey {
  id           String    @id
  name         String
  key_hash     String    @unique
  scopes       String[]
  last_used_at DateTime?
  created_at   DateTime  @default(now())
}

model Archive {
  id           String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  archive_type String
  archived_at  DateTime? @default(now())
  data         Json?
  created_at   DateTime? @default(now())
}

model AuditLog {
  id           String   @id
  user_id      String?
  action       String
  entity_type  String
  entity_id    String
  before_state Json?
  after_state  Json?
  ip_address   String?
  user_agent   String?
  created_at   DateTime @default(now())
  User         User?    @relation(fields: [user_id], references: [id])

  @@index([entity_type, entity_id])
}

model Milestone {
  id         String    @id
  project_id String
  title      String
  due_date   DateTime?
  is_locked  Boolean   @default(false)
  status     String    @default("pending")
  Project    Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model ProductionAIJob {
  id                     String                   @id
  project_id             String
  scene_id               String?
  shot_id                String?
  prompt_set_id          String?
  provider_id            String
  asset_type             String
  model_name             String
  status                 String                   @default("Queued")
  priority               String                   @default("Normal")
  created_by             String
  started_at             DateTime?
  completed_at           DateTime?
  error_message          String?
  external_job_id        String?
  metadata               Json?
  created_at             DateTime                 @default(now())
  updated_at             DateTime
  productionPromptId     String?
  ProductionPrompt       ProductionPrompt?        @relation(fields: [productionPromptId], references: [id])
  Project                Project                  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  ProductionAIProvider   ProductionAIProvider     @relation(fields: [provider_id], references: [id])
  ProductionScene        ProductionScene?         @relation(fields: [scene_id], references: [id])
  ProductionShot         ProductionShot?          @relation(fields: [shot_id], references: [id])
  ProductionAssetVersion ProductionAssetVersion[]
}

model ProductionAIProvider {
  id                           String                         @id
  name                         String                         @unique
  category                     String
  is_enabled                   Boolean                        @default(true)
  supported_asset_types        String[]
  supported_models             String[]
  capabilities                 Json?
  api_endpoint                 String?
  auth_type                    String
  status                       String                         @default("active")
  created_at                   DateTime                       @default(now())
  updated_at                   DateTime
  ProductionAIJob              ProductionAIJob[]
  ProductionProviderCredential ProductionProviderCredential[]
}

model ProductionActivityEvent {
  id          String   @id
  project_id  String
  event_type  String
  description String
  actor_id    String
  metadata    Json?
  created_at  DateTime @default(now())
}

model ProductionAsset {
  id                     String                   @id
  project_id             String
  scene_id               String?
  shot_id                String?
  prompt_set_id          String?
  creator_id             String?
  type                   String
  status                 String                   @default("Active")
  tags                   String[]
  current_version_id     String?
  created_at             DateTime                 @default(now())
  updated_at             DateTime
  productionPromptId     String?
  ProductionPrompt       ProductionPrompt?        @relation(fields: [productionPromptId], references: [id])
  Project                Project                  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  ProductionScene        ProductionScene?         @relation(fields: [scene_id], references: [id])
  ProductionShot         ProductionShot?          @relation(fields: [shot_id], references: [id])
  ProductionAssetVersion ProductionAssetVersion[]
}

model ProductionAssetPlaceholder {
  id               String           @id
  scene_id         String?
  shot_id          String?
  type             String
  status           String           @default("Pending")
  version          Int              @default(1)
  notes            String?
  assigned_to      String?
  future_ai_job_id String?
  created_at       DateTime         @default(now())
  updated_at       DateTime
  ProductionScene  ProductionScene? @relation(fields: [scene_id], references: [id], onDelete: Cascade)
  ProductionShot   ProductionShot?  @relation(fields: [shot_id], references: [id], onDelete: Cascade)
}

model ProductionAssetVersion {
  id              String           @id
  asset_id        String
  job_id          String?
  version_number  Int
  provider_id     String?
  model_name      String?
  prompt_snapshot Json?
  file_url        String?
  thumbnail_url   String?
  metadata        Json?
  notes           String?
  status          String           @default("Ready")
  is_current      Boolean          @default(true)
  created_at      DateTime         @default(now())
  updated_at      DateTime
  ProductionAsset ProductionAsset  @relation(fields: [asset_id], references: [id], onDelete: Cascade)
  ProductionAIJob ProductionAIJob? @relation(fields: [job_id], references: [id])
}

model ProductionAttachment {
  id            String   @id
  file_name     String
  file_type     String
  file_size     Int
  url           String
  uploader_id   String
  created_at    DateTime @default(now())
  updated_at    DateTime
  project_id    String?
  script_id     String?
  scene_id      String?
  shot_id       String?
  prompt_set_id String?
}

model ProductionChecklist {
  id                      String                    @id
  title                   String
  project_id              String
  target_type             String
  target_id               String?
  created_at              DateTime                  @default(now())
  updated_at              DateTime
  ProductionChecklistItem ProductionChecklistItem[]
}

model ProductionChecklistItem {
  id                  String              @id
  checklist_id        String
  content             String
  is_completed        Boolean             @default(false)
  is_required         Boolean             @default(true)
  completed_by        String?
  completed_at        DateTime?
  created_at          DateTime            @default(now())
  updated_at          DateTime
  ProductionChecklist ProductionChecklist @relation(fields: [checklist_id], references: [id], onDelete: Cascade)
}

model ProductionComment {
  id            String   @id
  content       String
  author_id     String
  resolved      Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime
  project_id    String?
  script_id     String?
  storyboard_id String?
  scene_id      String?
  shot_id       String?
  prompt_set_id String?
  parent_id     String?
}

model ProductionLog {
  id         String   @id
  project_id String
  type       String
  date       DateTime
  content    Json
  created_at DateTime @default(now())
  Project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model ProductionProviderCredential {
  id                   String               @id
  provider_id          String
  api_key_encrypted    String
  status               String               @default("Offline")
  last_tested_at       DateTime?
  last_used_at         DateTime?
  default_models       Json?
  created_at           DateTime             @default(now())
  updated_at           DateTime
  ProductionAIProvider ProductionAIProvider @relation(fields: [provider_id], references: [id], onDelete: Cascade)
}

model ProductionReference {
  id              String          @id
  scene_id        String
  title           String
  type            String
  uploader_id     String?
  thumbnail_url   String?
  url             String?
  created_at      DateTime        @default(now())
  updated_at      DateTime
  ProductionScene ProductionScene @relation(fields: [scene_id], references: [id], onDelete: Cascade)
}

model ProductionScript {
  id                    String                   @id
  project_id            String                   @unique
  version               Int                      @default(1)
  content               String?
  comments              Json?
  checklist             Json?
  is_approved           Boolean                  @default(false)
  is_locked             Boolean                  @default(false)
  created_at            DateTime                 @default(now())
  updated_at            DateTime
  Analyses              ProductionAnalysis[]
  Animals               ProductionAnimal[]
  ArtDirections         ProductionArtDirection[]
  Audios                ProductionAudio[]
  BrandAssets           ProductionBrandAsset[]
  CameraPlans           ProductionCameraPlan[]
  Characters            ProductionCharacter[]
  Lightings             ProductionLighting[]
  Locations             ProductionLocation[]
  Props                 ProductionProp[]
  Project               Project                  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  ProductionStoryboard  ProductionStoryboard?
  VFXs                  ProductionVFX[]
  Vehicles              ProductionVehicle[]
  ProductionVisualBible ProductionVisualBible?
}

model ProductionWorkflowDependency {
  id                                                                                          String                  @id
  stage_id                                                                                    String
  depends_on_id                                                                               String
  created_at                                                                                  DateTime                @default(now())
  ProductionWorkflowStage_ProductionWorkflowDependency_depends_on_idToProductionWorkflowStage ProductionWorkflowStage @relation("ProductionWorkflowDependency_depends_on_idToProductionWorkflowStage", fields: [depends_on_id], references: [id], onDelete: Cascade)
  ProductionWorkflowStage_ProductionWorkflowDependency_stage_idToProductionWorkflowStage      ProductionWorkflowStage @relation("ProductionWorkflowDependency_stage_idToProductionWorkflowStage", fields: [stage_id], references: [id], onDelete: Cascade)
}

model ProductionWorkflowStage {
  id                                                                                               String                         @id
  template_id                                                                                      String
  name                                                                                             String
  order_index                                                                                      Int
  required_role                                                                                    String?
  is_active                                                                                        Boolean                        @default(true)
  created_at                                                                                       DateTime                       @default(now())
  updated_at                                                                                       DateTime
  ProductionWorkflowDependency_ProductionWorkflowDependency_depends_on_idToProductionWorkflowStage ProductionWorkflowDependency[] @relation("ProductionWorkflowDependency_depends_on_idToProductionWorkflowStage")
  ProductionWorkflowDependency_ProductionWorkflowDependency_stage_idToProductionWorkflowStage      ProductionWorkflowDependency[] @relation("ProductionWorkflowDependency_stage_idToProductionWorkflowStage")
  ProductionWorkflowTemplate                                                                       ProductionWorkflowTemplate     @relation(fields: [template_id], references: [id], onDelete: Cascade)
}

model ProductionWorkflowTemplate {
  id                      String                    @id
  name                    String
  description             String?
  is_default              Boolean                   @default(false)
  created_at              DateTime                  @default(now())
  updated_at              DateTime
  ProductionWorkflowStage ProductionWorkflowStage[]
}

model Project {
  id                       String                        @id
  project_name             String
  project_ref              String?
  type                     String                        @default("Custom")
  status                   String                        @default("draft")
  progress                 Float                         @default(0)
  budget                   Float                         @default(0)
  deadline                 DateTime?
  color                    String?
  created_at               DateTime                      @default(now())
  updated_at               DateTime
  project_category         String?
  project_type             String                        @default("Normal Production")
  client_name              String?
  Milestone                Milestone[]
  ProductionAIJob          ProductionAIJob[]
  ProductionAnalysis       ProductionAnalysis[]
  ProductionAnimal         ProductionAnimal[]
  ProductionAnnotation     ProductionAnnotation[]
  ProductionApproval       ProductionApproval[]
  ProductionArtDirection   ProductionArtDirection[]
  ProductionAsset          ProductionAsset[]
  assistant_threads        ProductionAssistantThread[]
  ProductionAudio          ProductionAudio[]
  ProductionBrandAsset     ProductionBrandAsset[]
  ProductionCameraPlan     ProductionCameraPlan[]
  ProductionCharacter      ProductionCharacter[]
  ProductionColorPalette   ProductionColorPalette[]
  ProductionContinuity     ProductionContinuity[]
  ProductionCostume        ProductionCostume[]
  creative_memories        ProductionCreativeMemory[]
  generation_presets       ProductionGenerationPreset[]
  generation_sessions      ProductionGenerationSession[]
  ProductionLighting       ProductionLighting[]
  ProductionLocation       ProductionLocation[]
  ProductionLog            ProductionLog[]
  ProductionMakeup         ProductionMakeup[]
  ProductionMoodboard      ProductionMoodboard[]
  ProductionProp           ProductionProp[]
  ProductionReferenceImage ProductionReferenceImage[]
  ProductionReview         ProductionReview[]
  ProductionScript         ProductionScript?
  ProductionStoryboard     ProductionStoryboard?
  timeline_events          ProductionTimelineEvent[]
  ProductionVFX            ProductionVFX[]
  ProductionVehicle        ProductionVehicle[]
  ProductionVisualBible    ProductionVisualBible?
  ProductionVisualStyle    ProductionVisualStyle[]
  ProjectHealthScore       ProjectHealthScore?
  ProjectMember            ProjectMember[]
  ProjectStage             ProjectStage[]
}

model ProjectHealthScore {
  id                  String   @id
  project_id          String   @unique
  delivery_confidence Float
  budget_risk_score   Float
  burnout_risk_score  Float
  last_calculated_at  DateTime @default(now())
  ai_recommendations  Json
  Project             Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model ProjectMember {
  id         String   @id
  project_id String
  user_id    String
  role       String
  created_at DateTime @default(now())
  Project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  User       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([project_id, user_id])
}

model ProjectStage {
  id         String    @id
  project_id String
  name       String
  order      Int
  status     String    @default("pending")
  start_date DateTime?
  end_date   DateTime?
  Project    Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model Role {
  id          String   @id
  name        String   @unique
  permissions String[]
}

model SuperAdmin {
  id         String   @id
  email      String   @unique
  granted_at DateTime @default(now())
}

model User {
  id                  String                        @id
  role_id             String?
  email               String                        @unique
  fullName            String
  status              String                        @default("pending")
  department          String                        @default("Production")
  onboarding_status   String                        @default("awaiting_approval")
  skill_tags          String[]
  availability        String                        @default("available")
  productivity_score  Float                         @default(100.0)
  createdAt           DateTime                      @default(now())
  capacity_hours      Float                         @default(40)
  avatar              String?
  theme_preference    Json?
  AuditLog            AuditLog[]
  assistant_threads   ProductionAssistantThread[]
  creative_memories   ProductionCreativeMemory[]
  generation_presets  ProductionGenerationPreset[]
  generation_sessions ProductionGenerationSession[]
  timeline_events     ProductionTimelineEvent[]
  ProjectMember       ProjectMember[]
}

model ProductionAssistantThread {
  id         String                       @id @default(uuid())
  project_id String
  user_id    String
  title      String?
  created_at DateTime                     @default(now())
  updated_at DateTime                     @updatedAt
  messages   ProductionAssistantMessage[]
  project    Project                      @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user       User                         @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model ProductionAssistantMessage {
  id         String                    @id @default(uuid())
  thread_id  String
  role       String
  content    String
  created_at DateTime                  @default(now())
  thread     ProductionAssistantThread @relation(fields: [thread_id], references: [id], onDelete: Cascade)
}

model ProductionGenerationPreset {
  id         String   @id @default(uuid())
  project_id String
  user_id    String
  name       String
  category   String
  parameters Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model ProductionGenerationSession {
  id             String    @id @default(uuid())
  project_id     String
  user_id        String
  started_at     DateTime  @default(now())
  ended_at       DateTime?
  total_tokens   Int       @default(0)
  total_cost     Float     @default(0.0)
  providers_used String[]
  assets_created Int       @default(0)
  project        Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model ProductionCreativeMemory {
  id             String                            @id @default(uuid())
  project_id     String
  user_id        String
  type           String
  name           String
  description    String?
  attributes     Json
  prompt_snippet String
  created_at     DateTime                          @default(now())
  updated_at     DateTime                          @updatedAt
  project        Project                           @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user           User                              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  versions       ProductionCreativeMemoryVersion[]
  shots          ProductionShot[]                  @relation("ShotToMemory")
}

model ProductionCreativeMemoryVersion {
  id             String                   @id @default(uuid())
  memory_id      String
  version_number Int
  attributes     Json
  prompt_snippet String
  created_at     DateTime                 @default(now())
  created_by     String
  memory         ProductionCreativeMemory @relation(fields: [memory_id], references: [id], onDelete: Cascade)
}

model ProductionTimelineEvent {
  id          String   @id @default(uuid())
  project_id  String
  user_id     String
  entity_type String
  entity_id   String
  action      String
  metadata    Json?
  created_at  DateTime @default(now())
  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model ProductionCharacter {
  id               String              @id @default(uuid())
  project_id       String
  script_id        String
  name             String
  age              String?
  gender           String?
  description      String?
  personality      String?
  relationships    String?
  importance       String?
  first_appearance String?
  last_appearance  String?
  created_at       DateTime            @default(now())
  updated_at       DateTime            @updatedAt
  Project          Project             @relation(fields: [project_id], references: [id], onDelete: Cascade)
  ProductionScript ProductionScript    @relation(fields: [script_id], references: [id], onDelete: Cascade)
  Costumes         ProductionCostume[]
  Makeup           ProductionMakeup[]

  @@index([project_id])
  @@index([script_id])
}

model ProductionLocation {
  id               String           @id @default(uuid())
  project_id       String
  script_id        String
  name             String
  type             String?
  time_of_day      String?
  description      String?
  address          String?
  scene_count      Int              @default(0)
  reference_images Json?
  production_notes String?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  Project          Project          @relation(fields: [project_id], references: [id], onDelete: Cascade)
  ProductionScript ProductionScript @relation(fields: [script_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([script_id])
}

model ProductionProp {
  id               String           @id @default(uuid())
  project_id       String
  script_id        String
  name             String
  category         String?
  is_hero          Boolean          @default(false)
  quantity         Int              @default(1)
  scene_usage      String?
  continuity_notes String?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  Project          Project          @relation(fields: [project_id], references: [id], onDelete: Cascade)
  ProductionScript ProductionScript @relation(fields: [script_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([script_id])
}

model ProductionCostume {
  id            String              @id @default(uuid())
  project_id    String
  character_id  String
  outfit        String?
  shoes         String?
  accessories   String?
  hair          String?
  jewelry       String?
  color_palette String?
  notes         String?
  created_at    DateTime            @default(now())
  updated_at    DateTime            @updatedAt
  Character     ProductionCharacter @relation(fields: [character_id], references: [id], onDelete: Cascade)
  Project       Project             @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([character_id])
}

model ProductionMakeup {
  id           String              @id @default(uuid())
  project_id   String
  character_id String
  makeup_style String?
  fx_makeup    String?
  aging        String?
  blood        String?
  dirt         String?
  sweat        String?
  hair_style   String?
  created_at   DateTime            @default(now())
  updated_at   DateTime            @updatedAt
  Character    ProductionCharacter @relation(fields: [character_id], references: [id], onDelete: Cascade)
  Project      Project             @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([character_id])
}

model ProductionCameraPlan {
  id               String           @id @default(uuid())
  project_id       String
  script_id        String
  camera_style     String?
  shot_suggestions String?
  lens_suggestions String?
  movement         String?
  aspect_ratio     String?
  framing          String?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  Project          Project          @relation(fields: [project_id], references: [id], onDelete: Cascade)
  ProductionScript ProductionScript @relation(fields: [script_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([script_id])
}

model ProductionLighting {
  id               String           @id @default(uuid())
  project_id       String
  script_id        String
  lighting_style   String?
  mood             String?
  time_of_day      String?
  color_temp       String?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  Project          Project          @relation(fields: [project_id], references: [id], onDelete: Cascade)
  ProductionScript ProductionScript @relation(fields: [script_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([script_id])
}

model ProductionAudio {
  id               String           @id @default(uuid())
  project_id       String
  script_id        String
  dialogue         String?
  music            String?
  ambience         String?
  foley            String?
  sfx              String?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  Project          Project          @relation(fields: [project_id], references: [id], onDelete: Cascade)
  ProductionScript ProductionScript @relation(fields: [script_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([script_id])
}

model ProductionVFX {
  id               String           @id @default(uuid())
  project_id       String
  script_id        String
  cgi              String?
  fire             String?
  smoke            String?
  rain             String?
  explosions       String?
  particles        String?
  green_screen     String?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  Project          Project          @relation(fields: [project_id], references: [id], onDelete: Cascade)
  ProductionScript ProductionScript @relation(fields: [script_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([script_id])
}

model ProductionBrandAsset {
  id               String           @id @default(uuid())
  project_id       String
  script_id        String
  logos            String?
  products         String?
  brand_colors     String?
  brand_guidelines String?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  Project          Project          @relation(fields: [project_id], references: [id], onDelete: Cascade)
  ProductionScript ProductionScript @relation(fields: [script_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([script_id])
}

model ProductionVehicle {
  id               String           @id @default(uuid())
  project_id       String
  script_id        String
  name             String
  description      String?
  scene_usage      String?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  Project          Project          @relation(fields: [project_id], references: [id], onDelete: Cascade)
  ProductionScript ProductionScript @relation(fields: [script_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([script_id])
}

model ProductionAnimal {
  id               String           @id @default(uuid())
  project_id       String
  script_id        String
  species          String
  description      String?
  scene_usage      String?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  Project          Project          @relation(fields: [project_id], references: [id], onDelete: Cascade)
  ProductionScript ProductionScript @relation(fields: [script_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([script_id])
}

model ProductionArtDirection {
  id                String           @id @default(uuid())
  project_id        String
  script_id         String
  production_design String?
  color_palette     String?
  mood              String?
  references        String?
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt
  Project           Project          @relation(fields: [project_id], references: [id], onDelete: Cascade)
  ProductionScript  ProductionScript @relation(fields: [script_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([script_id])
}

model ProductionAnalysis {
  id                   String           @id @default(uuid())
  project_id           String
  script_id            String
  dialogue_analysis    Json?
  emotion_analysis     Json?
  talent_requirements  Json?
  crowd_requirements   Json?
  equipment_reqs       Json?
  budget_indicators    Json?
  risk_indicators      Json?
  schedule_suggestions Json?
  ai_recommendations   Json?
  created_at           DateTime         @default(now())
  updated_at           DateTime         @updatedAt
  Project              Project          @relation(fields: [project_id], references: [id], onDelete: Cascade)
  ProductionScript     ProductionScript @relation(fields: [script_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([script_id])
}

model ProductionStoryboard {
  id               String                        @id @default(uuid())
  project_id       String                        @unique
  script_id        String                        @unique
  is_completed     Boolean                       @default(false)
  created_at       DateTime                      @default(now())
  updated_at       DateTime                      @updatedAt
  ProductionScene  ProductionScene[]
  Project          Project                       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  ProductionScript ProductionScript              @relation(fields: [script_id], references: [id], onDelete: Cascade)
  Versions         ProductionStoryboardVersion[]
}

model ProductionStoryboardVersion {
  id             String               @id @default(uuid())
  storyboard_id  String
  version_number Int                  @default(1)
  content        Json
  status         String               @default("Draft")
  created_at     DateTime             @default(now())
  Storyboard     ProductionStoryboard @relation(fields: [storyboard_id], references: [id], onDelete: Cascade)

  @@index([storyboard_id])
}

model ProductionScene {
  id                         String                       @id @default(uuid())
  storyboard_id              String
  scene_number               Int
  title                      String
  description                String?
  duration                   String?
  notes                      String?
  status                     String                       @default("draft")
  created_at                 DateTime                     @default(now())
  updated_at                 DateTime                     @updatedAt
  completion_pct             Int                          @default(0)
  mood                       String?
  objective                  String?
  ProductionAIJob            ProductionAIJob[]
  ProductionAsset            ProductionAsset[]
  ProductionAssetPlaceholder ProductionAssetPlaceholder[]
  ProductionReference        ProductionReference[]
  ProductionStoryboard       ProductionStoryboard         @relation(fields: [storyboard_id], references: [id], onDelete: Cascade)
  Versions                   ProductionSceneVersion[]
  ProductionShot             ProductionShot[]
}

model ProductionSceneVersion {
  id             String          @id @default(uuid())
  scene_id       String
  version_number Int             @default(1)
  scene_type     String?
  time_of_day    String?
  location_ref   String?
  characters_ref String?
  props_ref      String?
  status         String          @default("Draft")
  created_at     DateTime        @default(now())
  Scene          ProductionScene @relation(fields: [scene_id], references: [id], onDelete: Cascade)

  @@index([scene_id])
}

model ProductionShot {
  id                         String                       @id @default(uuid())
  scene_id                   String
  shot_number                Int
  camera                     String?
  movement                   String?
  lens                       String?
  environment                String?
  character                  String?
  lighting                   String?
  duration                   String?
  created_at                 DateTime                     @default(now())
  updated_at                 DateTime                     @updatedAt
  ProductionAIJob            ProductionAIJob[]
  ProductionAsset            ProductionAsset[]
  ProductionAssetPlaceholder ProductionAssetPlaceholder[]
  ProductionPrompt           ProductionPrompt[]
  ProductionScene            ProductionScene              @relation(fields: [scene_id], references: [id], onDelete: Cascade)
  Versions                   ProductionShotVersion[]
  creative_memories          ProductionCreativeMemory[]   @relation("ShotToMemory")
}

model ProductionShotVersion {
  id                 String         @id @default(uuid())
  shot_id            String
  version_number     Int            @default(1)
  shot_type          String?
  camera_angle       String?
  lens               String?
  movement           String?
  composition        String?
  frame_size         String?
  focus              String?
  lighting           String?
  character_blocking String?
  dialogue           String?
  audio              String?
  fx                 String?
  status             String         @default("Draft")
  created_at         DateTime       @default(now())
  Shot               ProductionShot @relation(fields: [shot_id], references: [id], onDelete: Cascade)

  @@index([shot_id])
}

model ProductionPrompt {
  id              String                    @id @default(uuid())
  shot_id         String
  version         Int                       @default(1)
  status          String                    @default("Draft")
  created_at      DateTime                  @default(now())
  updated_at      DateTime                  @updatedAt
  completion_pct  Int                       @default(0)
  ProductionAIJob ProductionAIJob[]
  ProductionAsset ProductionAsset[]
  ProductionShot  ProductionShot            @relation(fields: [shot_id], references: [id], onDelete: Cascade)
  Versions        ProductionPromptVersion[]
}

model ProductionPromptVersion {
  id                 String           @id @default(uuid())
  prompt_id          String
  version_number     Int              @default(1)
  image_prompt       String?
  video_prompt       String?
  animation_prompt   String?
  environment_prompt String?
  character_prompt   String?
  camera_prompt      String?
  lighting_prompt    String?
  style_prompt       String?
  negative_prompt    String?
  seed               String?
  aspect_ratio       String?
  model_rec          String?
  provider_rec       String?
  quality_rec        String?
  status             String           @default("Draft")
  created_at         DateTime         @default(now())
  Prompt             ProductionPrompt @relation(fields: [prompt_id], references: [id], onDelete: Cascade)

  @@index([prompt_id])
}

model ProductionReferenceImage {
  id         String   @id @default(uuid())
  project_id String
  category   String
  entity_id  String?
  file_url   String
  version    Int      @default(1)
  created_at DateTime @default(now())
  Project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model ProductionMoodboard {
  id          String   @id @default(uuid())
  project_id  String
  title       String
  description String?
  images      Json
  created_at  DateTime @default(now())
  Project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model ProductionColorPalette {
  id         String   @id @default(uuid())
  project_id String
  name       String
  colors     Json
  created_at DateTime @default(now())
  Project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model ProductionContinuity {
  id          String   @id @default(uuid())
  project_id  String
  entity_type String
  entity_id   String
  notes       String
  scene_range String?
  created_at  DateTime @default(now())
  Project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model ProductionVisualStyle {
  id          String   @id @default(uuid())
  project_id  String
  style_name  String
  description String?
  created_at  DateTime @default(now())
  Project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model ProductionReview {
  id          String   @id @default(uuid())
  project_id  String
  entity_type String
  entity_id   String
  status      String
  reviewer_id String
  comments    String?
  created_at  DateTime @default(now())
  Project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model ProductionApproval {
  id          String   @id @default(uuid())
  project_id  String
  entity_type String
  entity_id   String
  approved_by String
  approved_at DateTime @default(now())
  Project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model ProductionAnnotation {
  id          String   @id @default(uuid())
  project_id  String
  entity_type String
  entity_id   String
  coordinates Json?
  content     String
  created_at  DateTime @default(now())
  Project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model ProductionVisualBible {
  id               String                         @id @default(uuid())
  project_id       String                         @unique
  script_id        String                         @unique
  is_completed     Boolean                        @default(false)
  created_at       DateTime                       @default(now())
  updated_at       DateTime                       @updatedAt
  Project          Project                        @relation(fields: [project_id], references: [id], onDelete: Cascade)
  ProductionScript ProductionScript               @relation(fields: [script_id], references: [id], onDelete: Cascade)
  Versions         ProductionVisualBibleVersion[]
}

model ProductionVisualBibleVersion {
  id                   String                @id @default(uuid())
  visual_bible_id      String
  version_number       Int                   @default(1)
  style_bible          Json?
  character_bible      Json?
  location_bible       Json?
  prop_bible           Json?
  costume_bible        Json?
  cinematography_bible Json?
  lighting_bible       Json?
  art_direction_bible  Json?
  audio_bible          Json?
  vfx_bible            Json?
  status               String                @default("Draft")
  created_at           DateTime              @default(now())
  VisualBible          ProductionVisualBible @relation(fields: [visual_bible_id], references: [id], onDelete: Cascade)

  @@index([visual_bible_id])
}
