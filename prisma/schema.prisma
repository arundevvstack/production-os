generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AIGenerationJob {
  id              String   @id
  project_id      String
  provider        String
  model           String
  prompt          String
  status          String
  cost_credits    Float    @default(0)
  compute_time_ms Int      @default(0)
  result_urls     String[]
  error_log       String?
  created_at      DateTime @default(now())
  Project         Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model AIOperationalMemory {
  id           String   @id
  company_id   String
  entity_type  String
  entity_id    String
  memory_key   String
  memory_value Json
  confidence   Float
  last_updated DateTime
  Company      Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id             String   @id
  company_id     String
  user_id        String
  user_name      String
  action         String
  details        String?
  previous_state Json?
  new_state      Json?
  created_at     DateTime @default(now())
  Company        Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  User           User     @relation(fields: [user_id], references: [id])
}

model ApiKey {
  id           String    @id
  company_id   String
  name         String
  key_hash     String    @unique
  scopes       String[]
  last_used_at DateTime?
  created_at   DateTime  @default(now())
  Company      Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model Approval {
  id           String    @id
  objective_id String
  requester_id String
  reviewer_id  String?
  status       String    @default("Pending")
  feedback     String?
  review_round Int       @default(1)
  requested_at DateTime  @default(now())
  reviewed_at  DateTime?
  Objective    Objective @relation(fields: [objective_id], references: [id], onDelete: Cascade)
  User         User      @relation(fields: [requester_id], references: [id])
}

model ApprovalChain {
  id              String            @id
  company_id      String
  name            String
  target_type     String
  stages          Json
  created_at      DateTime          @default(now())
  Company         Company           @relation(fields: [company_id], references: [id], onDelete: Cascade)
  ApprovalRequest ApprovalRequest[]
}

model ApprovalHistory {
  id              String          @id
  request_id      String
  step            Int
  actor_id        String
  action          String
  comment         String?
  created_at      DateTime        @default(now())
  User            User            @relation(fields: [actor_id], references: [id], onDelete: Cascade)
  ApprovalRequest ApprovalRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)
}

model ApprovalRequest {
  id              String            @id
  chain_id        String
  company_id      String
  entity_id       String
  status          String
  current_step    Int               @default(1)
  due_date        DateTime?
  created_at      DateTime          @default(now())
  updated_at      DateTime
  ApprovalHistory ApprovalHistory[]
  ApprovalChain   ApprovalChain     @relation(fields: [chain_id], references: [id], onDelete: Cascade)
  Company         Company           @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model Archive {
  id           String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  company_id   String?
  archive_type String
  archived_at  DateTime? @default(now())
  data         Json?
  created_at   DateTime? @default(now())
}

model Asset {
  id           String     @id
  company_id   String
  project_id   String
  objective_id String?
  name         String
  url          String
  file_size    Int?
  file_type    String?
  version      Int        @default(1)
  created_at   DateTime   @default(now())
  metadata     Json?
  parent_id    String?
  Company      Company    @relation(fields: [company_id], references: [id], onDelete: Cascade)
  Objective    Objective? @relation(fields: [objective_id], references: [id])
  Project      Project    @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model AuditLog {
  id           String   @id
  company_id   String
  user_id      String?
  action       String
  entity_type  String
  entity_id    String
  before_state Json?
  after_state  Json?
  ip_address   String?
  user_agent   String?
  created_at   DateTime @default(now())
  Company      Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  User         User?    @relation(fields: [user_id], references: [id])

  @@index([company_id])
  @@index([entity_type, entity_id])
}

model AutoRemediationAction {
  id                     String                 @id
  incident_id            String
  action_type            String
  success                Boolean                @default(false)
  logs                   String?
  executed_at            DateTime               @default(now())
  InfrastructureIncident InfrastructureIncident @relation(fields: [incident_id], references: [id], onDelete: Cascade)
}

model AutomationRule {
  id            String  @id
  company_id    String
  name          String
  trigger_event String
  conditions    Json
  actions       Json
  is_active     Boolean @default(true)
  Company       Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model BankAccount {
  id             String   @id
  company_id     String
  name           String
  type           String   @default("Bank")
  balance        Float    @default(0)
  account_number String?
  bank_name      String?
  created_at     DateTime @default(now())
  Company        Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model Booking {
  id          String   @id
  company_id  String
  resource_id String
  project_id  String
  start_date  DateTime
  end_date    DateTime
  status      String   @default("confirmed")
  created_at  DateTime @default(now())
  Project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  Resource    Resource @relation(fields: [resource_id], references: [id], onDelete: Cascade)
}

model Budget {
  id              String  @id
  project_id      String  @unique
  estimated_cost  Float
  approved_budget Float
  utilized_budget Float   @default(0)
  currency        String  @default("USD")
  Project         Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Client {
  id                  String               @id
  company_id          String
  name                String
  contact_person      String?
  email               String?
  phone               String?
  industry            String?
  billing_address     String?
  gstin               String?
  created_at          DateTime             @default(now())
  service_vertical    String?
  sub_vertical        String?
  logo_url            String?
  wallpaper_url       String?
  Company             Company              @relation(fields: [company_id], references: [id], onDelete: Cascade)
  ClientPortalSetting ClientPortalSetting?
  Invoice             Invoice[]
  Project             Project[]
  Prospect            Prospect[]
  RevisionRequest     RevisionRequest[]
}

model ClientPortalSetting {
  id               String  @id
  client_id        String  @unique
  brand_color      String?
  logo_url         String?
  custom_domain    String?
  features_enabled Json
  Client           Client  @relation(fields: [client_id], references: [id], onDelete: Cascade)
}

model Comment {
  id           String     @id
  company_id   String
  project_id   String?
  objective_id String?
  user_id      String
  content      String
  timestamp    String?
  created_at   DateTime   @default(now())
  prospect_id  String?
  is_edited    Boolean    @default(false)
  reactions    Json?      @default("[]")
  updated_at   DateTime?
  edit_history Json?      @default("[]")
  Company      Company    @relation(fields: [company_id], references: [id], onDelete: Cascade)
  Objective    Objective? @relation(fields: [objective_id], references: [id], onDelete: Cascade)
  Project      Project?   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  Prospect     Prospect?  @relation(fields: [prospect_id], references: [id], onDelete: Cascade)
  User         User       @relation(fields: [user_id], references: [id])
}

model CommunicationLog {
  id          String   @id
  company_id  String
  prospect_id String
  type        String
  summary     String
  logged_at   DateTime @default(now())
  Company     Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  Prospect    Prospect @relation(fields: [prospect_id], references: [id], onDelete: Cascade)
}

model Company {
  id                           String                         @id
  name                         String
  onboardingStatus             String                         @default("pending")
  cin                          String?
  gstin                        String?
  address                      String?
  bank_details                 Json?
  contact_email                String?
  contact_phone                String?
  website                      String?
  createdAt                    DateTime                       @default(now())
  updatedAt                    DateTime
  AIOperationalMemory          AIOperationalMemory[]
  ActivityLog                  ActivityLog[]
  ApiKey                       ApiKey[]
  ApprovalChain                ApprovalChain[]
  ApprovalRequest              ApprovalRequest[]
  Asset                        Asset[]
  AuditLog                     AuditLog[]
  AutomationRule               AutomationRule[]
  BankAccount                  BankAccount[]
  Client                       Client[]
  Comment                      Comment[]
  CommunicationLog             CommunicationLog[]
  CompanyPluginInstallation    CompanyPluginInstallation[]
  CompanySettings              CompanySettings?
  Competitor                   Competitor[]
  Deliverable                  Deliverable[]
  Expense                      Expense[]
  GSTFiling                    GSTFiling[]
  IndustryTrend                IndustryTrend[]
  Invoice                      Invoice[]
  MarketAlert                  MarketAlert[]
  MarketLead                   MarketLead[]
  MarketOpportunity            MarketOpportunity[]
  MarketResearchNote           MarketResearchNote[]
  Notification                 Notification[]
  NotificationQueue            NotificationQueue[]
  OperationalTelemetry         OperationalTelemetry[]
  ProductionProviderCredential ProductionProviderCredential[]
  Project                      Project[]
  Proposal                     Proposal[]
  Prospect                     Prospect[]
  Resource                     Resource[]
  Talent                       Talent[]
  Team                         Team[]
  TenantMarginForecast         TenantMarginForecast?
  TenantSlaMetrics             TenantSlaMetrics?
  TenantSubscription           TenantSubscription?
  User                         User[]
  Vendor                       Vendor[]
  WebhookEndpoint              WebhookEndpoint[]
  WorkflowTemplate             WorkflowTemplate[]
}

model CompanyPluginInstallation {
  id                String            @id
  company_id        String
  plugin_id         String
  config_json       Json              @default("{}")
  installed_at      DateTime          @default(now())
  granted_scopes    String[]          @default([])
  is_active         Boolean           @default(true)
  Company           Company           @relation(fields: [company_id], references: [id], onDelete: Cascade)
  MarketplacePlugin MarketplacePlugin @relation(fields: [plugin_id], references: [id], onDelete: Cascade)
}

model CompanySettings {
  id               String   @id
  company_id       String   @unique
  modules_enabled  String[]
  currency         String   @default("INR")
  timezone         String   @default("Asia/Kolkata")
  updated_at       DateTime @default(now())
  theme            Json?
  role_permissions Json?
  Company          Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model Competitor {
  id                 String               @id
  company_id         String
  brand_name         String
  campaigns_count    Int                  @default(0)
  video_style        String?
  ai_usage           String?
  social_quality     String?
  engagement_rate    String?
  branding_style     String?
  pricing            String?
  service_offerings  String?
  production_quality String?
  weaknesses         String[]             @default([])
  created_at         DateTime             @default(now())
  updated_at         DateTime
  Company            Company              @relation(fields: [company_id], references: [id], onDelete: Cascade)
  CompetitorActivity CompetitorActivity[]
}

model CompetitorActivity {
  id            String     @id
  competitor_id String
  activity_type String
  description   String
  impact        String?
  detected_at   DateTime   @default(now())
  Competitor    Competitor @relation(fields: [competitor_id], references: [id], onDelete: Cascade)
}

model Deliverable {
  id              String            @id
  company_id      String
  project_id      String
  title           String
  status          String            @default("pending")
  due_date        DateTime?
  url             String?
  version         Int               @default(1)
  created_at      DateTime          @default(now())
  Company         Company           @relation(fields: [company_id], references: [id], onDelete: Cascade)
  Project         Project           @relation(fields: [project_id], references: [id], onDelete: Cascade)
  RevisionRequest RevisionRequest[]
}

model DistributedJobQueue {
  id             String    @id
  job_type       String
  payload        Json
  status         String    @default("pending")
  priority       Int       @default(0)
  worker_id      String?
  started_at     DateTime?
  completed_at   DateTime?
  error_log      String?
  created_at     DateTime  @default(now())
  max_retries    Int       @default(3)
  next_retry_at  DateTime?
  retry_count    Int       @default(0)
  schema_version String    @default("1.0")
  trace_id       String?
  updated_at     DateTime
}

model Expense {
  id          String   @id
  company_id  String
  project_id  String?
  category    String
  description String?
  amount      Float
  date        DateTime
  account_id  String?
  status      String
  created_at  DateTime @default(now())
  vendor_id   String?
  Company     Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  Project     Project? @relation(fields: [project_id], references: [id])
  Vendor      Vendor?  @relation(fields: [vendor_id], references: [id])
}

model FreelancerBid {
  id             String    @id
  objective_id   String
  freelancer_id  String
  proposed_rate  Float
  estimated_days Int
  status         String    @default("pending")
  Objective      Objective @relation(fields: [objective_id], references: [id], onDelete: Cascade)
}

model GSTFiling {
  id           String   @id
  company_id   String
  period       String
  gst_output   Float
  arn_number   String?
  status       String
  submitted_at DateTime @default(now())
  Company      Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model IndustryTrend {
  id                  String   @id
  company_id          String
  title               String
  source              String
  velocity_score      Int      @default(0)
  viral_format        String?
  upcoming_prediction String?
  detected_at         DateTime @default(now())
  Company             Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model InfrastructureIncident {
  id                    String                  @id
  component             String
  error_message         String
  severity              String
  resolved              Boolean                 @default(false)
  timestamp             DateTime                @default(now())
  AutoRemediationAction AutoRemediationAction[]
}

model Invoice {
  id             String    @id
  company_id     String
  client_id      String?
  project_id     String?
  invoice_number String    @unique
  total          Float
  subtotal       Float
  gst_amount     Float
  payment_status String
  issue_date     DateTime?
  due_date       DateTime?
  gst_filed      Boolean   @default(false)
  line_items     Json
  created_at     DateTime  @default(now())
  Client         Client?   @relation(fields: [client_id], references: [id])
  Company        Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model LeadScore {
  id                     String     @id
  lead_id                String
  revenue_potential      Int        @default(0)
  ai_readiness           Int        @default(0)
  marketing_maturity     Int        @default(0)
  urgency                Int        @default(0)
  competition_score      Int        @default(0)
  conversion_probability Float      @default(0)
  final_score            Int        @default(0)
  calculated_at          DateTime   @default(now())
  MarketLead             MarketLead @relation(fields: [lead_id], references: [id], onDelete: Cascade)
}

model LiveCollaborationSession {
  id            String   @id
  project_id    String
  active_users  String[]
  session_state Json
  started_at    DateTime @default(now())
  Project       Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model MarketAlert {
  id           String   @id
  company_id   String
  type         String
  message      String
  is_dismissed Boolean  @default(false)
  created_at   DateTime @default(now())
  Company      Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model MarketLead {
  id                 String             @id
  company_id         String
  opportunity_id     String?
  company_name       String
  industry           String
  website            String?
  instagram          String?
  linkedin           String?
  contact_email      String?
  location           String?
  marketing_quality  String?
  brand_quality      String?
  services_needed    String?
  growth_potential   String?
  estimated_budget   Float              @default(0)
  ai_readiness       Int                @default(0)
  opportunity_score  Int                @default(0)
  score_label        String?
  is_synced          Boolean            @default(false)
  synced_prospect_id String?
  created_at         DateTime           @default(now())
  updated_at         DateTime
  LeadScore          LeadScore[]
  Company            Company            @relation(fields: [company_id], references: [id], onDelete: Cascade)
  MarketOpportunity  MarketOpportunity? @relation(fields: [opportunity_id], references: [id])
}

model MarketOpportunity {
  id              String       @id
  company_id      String
  industry        String
  region          String?
  gap_description String
  severity        String
  ad_style        String?
  ai_readiness    Int          @default(0)
  impact_score    Int          @default(0)
  status          String       @default("open")
  owner_id        String?
  created_at      DateTime     @default(now())
  updated_at      DateTime
  MarketLead      MarketLead[]
  Company         Company      @relation(fields: [company_id], references: [id], onDelete: Cascade)
  User            User?        @relation(fields: [owner_id], references: [id])
}

model MarketResearchNote {
  id         String   @id
  company_id String
  user_id    String
  content    String
  created_at DateTime @default(now())
  updated_at DateTime
  Company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  User       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model MarketplacePlugin {
  id                        String                      @id
  name                      String
  description               String
  developer_name            String
  plugin_type               String
  price_monthly             Float                       @default(0.00)
  is_verified               Boolean                     @default(false)
  required_scopes           String[]                    @default([])
  CompanyPluginInstallation CompanyPluginInstallation[]
}

model Meeting {
  id           String    @id
  prospect_id  String?
  project_id   String?
  title        String
  scheduled_at DateTime
  duration     Int
  notes        String?
  created_at   DateTime  @default(now())
  Project      Project?  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  Prospect     Prospect? @relation(fields: [prospect_id], references: [id], onDelete: Cascade)
}

model Milestone {
  id         String    @id
  project_id String
  title      String
  due_date   DateTime?
  is_locked  Boolean   @default(false)
  status     String    @default("pending")
  Project    Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model Notification {
  id         String   @id
  company_id String
  user_id    String
  title      String
  message    String
  type       String   @default("info")
  link       String?
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  Company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  User       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model NotificationPreference {
  id         String   @id
  user_id    String   @unique
  channels   Json
  updated_at DateTime
  User       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model NotificationQueue {
  id           String    @id
  company_id   String
  user_id      String
  channel      String
  title        String
  body         String
  priority     String    @default("MEDIUM")
  status       String    @default("queued")
  retry_count  Int       @default(0)
  scheduled_at DateTime  @default(now())
  sent_at      DateTime?
  Company      Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  User         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Objective {
  id                                                           String                @id
  project_id                                                   String
  stage_id                                                     String?
  title                                                        String
  description                                                  String?
  department                                                   String?
  status                                                       String                @default("Pending")
  priority                                                     String                @default("Medium")
  assignee_id                                                  String?
  reviewer_id                                                  String?
  start_date                                                   DateTime?
  due_date                                                     DateTime?
  estimated_hours                                              Float?
  actual_hours                                                 Float                 @default(0)
  completion_pct                                               Float                 @default(0)
  checklist                                                    Json?
  created_at                                                   DateTime              @default(now())
  updated_at                                                   DateTime
  is_blocked                                                   Boolean               @default(false)
  attachment_count                                             Int                   @default(0)
  revision_count                                               Int                   @default(0)
  template_id                                                  String?
  Approval                                                     Approval[]
  Asset                                                        Asset[]
  Comment                                                      Comment[]
  FreelancerBid                                                FreelancerBid[]
  User_Objective_assignee_idToUser                             User?                 @relation("Objective_assignee_idToUser", fields: [assignee_id], references: [id])
  Project                                                      Project               @relation(fields: [project_id], references: [id], onDelete: Cascade)
  User_Objective_reviewer_idToUser                             User?                 @relation("Objective_reviewer_idToUser", fields: [reviewer_id], references: [id])
  ProjectStage                                                 ProjectStage?         @relation(fields: [stage_id], references: [id])
  ObjectiveDependency_ObjectiveDependency_child_idToObjective  ObjectiveDependency[] @relation("ObjectiveDependency_child_idToObjective")
  ObjectiveDependency_ObjectiveDependency_parent_idToObjective ObjectiveDependency[] @relation("ObjectiveDependency_parent_idToObjective")
  TimeEntry                                                    TimeEntry[]
}

model ObjectiveDependency {
  id                                                 String    @id
  parent_id                                          String
  child_id                                           String
  type                                               String    @default("blocking")
  Objective_ObjectiveDependency_child_idToObjective  Objective @relation("ObjectiveDependency_child_idToObjective", fields: [child_id], references: [id], onDelete: Cascade)
  Objective_ObjectiveDependency_parent_idToObjective Objective @relation("ObjectiveDependency_parent_idToObjective", fields: [parent_id], references: [id], onDelete: Cascade)

  @@unique([parent_id, child_id])
}

model OperationalTelemetry {
  id           String   @id
  company_id   String
  metric_type  String
  metric_value Float
  context      Json
  timestamp    DateTime @default(now())
  Company      Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model ProductionAIJob {
  id                     String                   @id
  project_id             String
  scene_id               String?
  shot_id                String?
  prompt_set_id          String?
  provider_id            String
  asset_type             String
  model_name             String
  status                 String                   @default("Queued")
  priority               String                   @default("Normal")
  created_by             String
  started_at             DateTime?
  completed_at           DateTime?
  error_message          String?
  external_job_id        String?
  metadata               Json?
  created_at             DateTime                 @default(now())
  updated_at             DateTime
  Project                Project                  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  ProductionPromptSet    ProductionPromptSet?     @relation(fields: [prompt_set_id], references: [id])
  ProductionAIProvider   ProductionAIProvider     @relation(fields: [provider_id], references: [id])
  ProductionScene        ProductionScene?         @relation(fields: [scene_id], references: [id])
  ProductionShot         ProductionShot?          @relation(fields: [shot_id], references: [id])
  ProductionAssetVersion ProductionAssetVersion[]
}

model ProductionAIProvider {
  id                           String                         @id
  name                         String                         @unique
  category                     String
  is_enabled                   Boolean                        @default(true)
  supported_asset_types        String[]
  supported_models             String[]
  capabilities                 Json?
  api_endpoint                 String?
  auth_type                    String
  status                       String                         @default("active")
  created_at                   DateTime                       @default(now())
  updated_at                   DateTime
  ProductionAIJob              ProductionAIJob[]
  ProductionProviderCredential ProductionProviderCredential[]
}

model ProductionActivityEvent {
  id          String   @id
  project_id  String
  event_type  String
  description String
  actor_id    String
  metadata    Json?
  created_at  DateTime @default(now())
}

model ProductionAsset {
  id                     String                   @id
  project_id             String
  scene_id               String?
  shot_id                String?
  prompt_set_id          String?
  creator_id             String?
  type                   String
  status                 String                   @default("Active")
  tags                   String[]
  current_version_id     String?
  created_at             DateTime                 @default(now())
  updated_at             DateTime
