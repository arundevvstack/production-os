generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id               String   @id @default(uuid())
  name             String
  onboardingStatus String   @default("pending")
  cin              String?
  gstin            String?
  address          String?
  bank_details     Json?    // Stores bank_name, account_no, ifsc, branch, pan
  contact_email    String?
  contact_phone    String?
  website          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users            User[]
  leads            Lead[]
  projects         Project[]
  invoices         Invoice[]
  gstFilings       GSTFiling[]
  expenses         Expense[]
  proposals        Proposal[]
  talents          Talent[]
  resources        Resource[]

  settings         CompanySettings?
  assets           Asset[]
  deliverables     Deliverable[]
  comments         Comment[]
  notifications    Notification[]
  activityLogs     ActivityLog[]
}

model User {
  id                String   @id // Maps to Supabase Auth ID
  company_id        String?
  company           Company? @relation(fields: [company_id], references: [id], onDelete: Cascade)
  role_id           String   @default("EMPLOYEE") // SUPER_ADMIN, MANAGER, EMPLOYEE, ACCOUNTS, MARKETING_SALES
  email             String   @unique
  fullName          String
  status            String   @default("pending")  // pending, approved, suspended
  onboarding_status String   @default("awaiting_approval") // awaiting_approval, completed
  department        String   @default("Production")       // e.g. Production, Accounts, Creative, Sales
  createdAt         DateTime @default(now())

  @@index([company_id])
  @@index([status])
}

model SuperAdmin {
  id         String   @id // Maps to Supabase Auth ID
  email      String   @unique
  granted_at DateTime @default(now())
}

model CompanySettings {
  id              String   @id @default(uuid())
  company_id      String   @unique
  company         Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  modules_enabled String[] // Array of enabled modules (e.g. CRM, Projects, Talent)
  currency        String   @default("INR")
  timezone        String   @default("Asia/Kolkata")
  theme           Json?    // Custom workspace branding colors
  updated_at      DateTime @default(now()) @updatedAt

  @@index([company_id])
}

model Lead {
  id               String   @id @default(uuid())
  company_id       String
  company          Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  company_name     String?
  email            String?
  contact_person   String?
  industry         String?
  service_vertical String?
  sub_vertical     String?
  deal_value       Float?
  stage            String?
  billing_address  String?
  gstin            String?
  created_at       DateTime @default(now())

  @@index([company_id])
  @@index([stage])
}

model Project {
  id           String   @id @default(uuid())
  company_id   String
  company      Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  project_name String
  project_ref  String?
  client_name  String?
  status       String
  progress     Float    @default(0)
  budget       Float    @default(0)
  deadline     DateTime?
  color        String?
  created_at   DateTime @default(now())
  
  tasks        Task[]
  assets       Asset[]
  deliverables Deliverable[]
  comments     Comment[]
  bookings     Booking[]

  @@index([company_id])
  @@index([status])
}

model Task {
  id          String   @id @default(uuid())
  project_id  String
  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  company_id  String   // Redundant but useful for cross-project queries
  title       String
  status      String   @default("pending")
  due_date    DateTime?
  created_at  DateTime @default(now())

  @@index([company_id])
  @@index([project_id])
  @@index([status])
}

model Resource {
  id                 String    @id @default(uuid())
  company_id         String
  company            Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  name               String
  type               String    // Camera, Drone, Lighting, Studio, Editor, Vehicle, Audio, Render System, Space
  status             String    @default("available") // available, booked, maintenance
  maintenance_status String    @default("good")      // good, servicing, broken
  created_at         DateTime  @default(now())

  bookings           Booking[]

  @@index([company_id])
}

model Booking {
  id          String   @id @default(uuid())
  company_id  String
  resource_id String
  resource    Resource @relation(fields: [resource_id], references: [id], onDelete: Cascade)
  project_id  String
  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  start_date  DateTime
  end_date    DateTime
  status      String   @default("confirmed") // pending, confirmed, cancelled
  created_at  DateTime @default(now())

  @@index([company_id])
  @@index([resource_id])
  @@index([project_id])
}

model Asset {
  id          String   @id @default(uuid())
  company_id  String
  company     Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  project_id  String
  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  name        String
  url         String
  file_size   Int?
  file_type   String?
  created_at  DateTime @default(now())

  @@index([company_id])
  @@index([project_id])
}

model Deliverable {
  id          String   @id @default(uuid())
  company_id  String
  company     Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  project_id  String
  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  title       String
  status      String   @default("pending") // pending, in_progress, approved, rejected
  due_date    DateTime?
  url         String?
  created_at  DateTime @default(now())

  @@index([company_id])
  @@index([project_id])
}

model Comment {
  id          String   @id @default(uuid())
  company_id  String
  company     Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  project_id  String
  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user_id     String
  user_name   String
  content     String
  created_at  DateTime @default(now())

  @@index([company_id])
  @@index([project_id])
}

model Notification {
  id          String   @id @default(uuid())
  company_id  String
  company     Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  user_id     String   // Recipient User ID
  title       String
  message     String
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now())

  @@index([company_id])
  @@index([user_id])
}

model ActivityLog {
  id          String   @id @default(uuid())
  company_id  String
  company     Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  user_id     String
  user_name   String
  action      String
  details     String?
  created_at  DateTime @default(now())

  @@index([company_id])
  @@index([created_at])
}

model Invoice {
  id             String   @id @default(uuid())
  company_id     String
  company        Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  client_name    String?
  client_id      String?
  project_id     String?
  project_name   String?
  project_ref    String?
  invoice_number String   @unique
  total          Float
  subtotal       Float
  gst_amount     Float
  payment_status String
  issue_date     DateTime?
  due_date       DateTime?
  gst_filed      Boolean  @default(false)
  line_items     Json     // Array of {description, unit_price, quantity, total}
  created_at     DateTime @default(now())

  @@index([company_id])
  @@index([payment_status])
}

model GSTFiling {
  id           String   @id @default(uuid())
  company_id   String
  company      Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  period       String
  gst_output   Float
  arn_number   String?
  status       String
  submitted_at DateTime @default(now())

  @@index([company_id])
}

model Expense {
  id          String   @id @default(uuid())
  company_id  String
  company     Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  project_id  String?
  category    String
  description String?
  amount      Float
  date        DateTime
  account_id  String?
  status      String
  created_at  DateTime @default(now())

  @@index([company_id])
  @@index([project_id])
}

model Proposal {
  id              String   @id @default(uuid())
  company_id      String
  company         Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  lead_id         String?
  title           String
  client_name     String?
  proposal_number String?
  content         String   // Structured JSON blueprint stringified
  status          String
  created_at      DateTime @default(now())

  @@index([company_id])
  @@index([status])
}

model Talent {
  id              String   @id @default(uuid())
  company_id      String
  company         Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  full_name       String
  category        String
  location        String?
  followers       Int      @default(0)
  engagement_rate Float    @default(0)
  is_public       Boolean  @default(true)
  portfolio_urls  String[] // Postgres array
  created_at      DateTime @default(now())

  @@index([company_id])
}
