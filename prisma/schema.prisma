generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --------------------------------------------------
// USERS, TEAMS & ROLES
// --------------------------------------------------

model Company {
  id               String   @id @default(uuid())
  name             String
  onboardingStatus String   @default("pending")
  cin              String?
  gstin            String?
  address          String?
  bank_details     Json?
  contact_email    String?
  contact_phone    String?
  website          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  settings          CompanySettings?
  users             User[]
  teams             Team[]
  clients           Client[]
  prospects         Prospect[]
  projects          Project[]
  assets            Asset[]
  deliverables      Deliverable[]
  expenses          Expense[]
  invoices          Invoice[]
  notifications     Notification[]
  activityLogs      ActivityLog[]
  resources         Resource[]
  talents           Talent[]
  bankAccounts      BankAccount[]
  gstFilings        GSTFiling[]
  proposals         Proposal[]
  communicationLogs CommunicationLog[]
  Comment           Comment[]

  workflow_templates WorkflowTemplate[]
  audit_logs         AuditLog[]
  approval_chains    ApprovalChain[]
  approval_requests  ApprovalRequest[]
  notification_queues NotificationQueue[]
}

model CompanySettings {
  id              String   @id @default(uuid())
  company_id      String   @unique
  modules_enabled String[]
  currency        String   @default("INR")
  timezone        String   @default("Asia/Kolkata")
  updated_at      DateTime @default(now()) @updatedAt
  theme           Json?
  company         Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // "SUPER_ADMIN", "ADMIN", "PROJECT_DIRECTOR", "PROJECT_MANAGER", "DEPT_HEAD", "TEAM_MEMBER", "CLIENT", "VENDOR"
  permissions String[] // Array of permission strings
}

model Team {
  id         String     @id @default(uuid())
  company_id String
  name       String
  department String
  created_at DateTime   @default(now())
  company    Company    @relation(fields: [company_id], references: [id], onDelete: Cascade)
  users      UserTeam[]
}

model UserTeam {
  user_id String
  team_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  team    Team   @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@id([user_id, team_id])
}

model User {
  id                 String   @id // Usually from Supabase Auth
  company_id         String?
  role_id            String?  // Stores role NAME string: SUPER_ADMIN, MANAGER, EMPLOYEE, etc.
  email              String   @unique
  fullName           String
  status             String   @default("pending")
  department         String   @default("Production")
  onboarding_status  String   @default("awaiting_approval")
  skill_tags         String[]
  availability       String   @default("available") // available, busy, offline
  productivity_score Float    @default(100.0)
  createdAt          DateTime @default(now())

  company Company?   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  teams   UserTeam[]

  assigned_prospects  Prospect[]  @relation("ProspectAssignee")
  assigned_objectives Objective[] @relation("ObjectiveAssignee")
  reviewed_objectives Objective[] @relation("ObjectiveReviewer")

  time_entries  TimeEntry[]
  comments      Comment[]
  notifications Notification[]
  activityLogs  ActivityLog[]
  approvals     Approval[]

  audit_logs              AuditLog[]
  approval_histories      ApprovalHistory[]
  notification_preferences NotificationPreference?
  queued_notifications    NotificationQueue[]

  @@index([company_id])
}

// --------------------------------------------------
// CRM & PIPELINE
// --------------------------------------------------

model Client {
  id               String   @id @default(uuid())
  company_id       String
  name             String
  contact_person   String?
  email            String?
  phone            String?
  industry         String?
  billing_address  String?
  gstin            String?
  service_vertical String?
  sub_vertical     String?
  created_at       DateTime @default(now())

  company   Company    @relation(fields: [company_id], references: [id], onDelete: Cascade)
  projects  Project[]
  invoices  Invoice[]
  prospects Prospect[]
}

model Prospect {
  id         String  @id @default(uuid())
  company_id String

  company_name     String
  contact_person   String?
  email            String?
  phone            String?
  whatsapp         String?
  social_links     Json? // { linkedin: "", instagram: "" }
  industry         String?
  project_category String? // e.g. "AI TVC", "Corporate Film"
  service_vertical String? // e.g. "Advertising & Brand Films"
  sub_vertical     String? // e.g. "TV Commercials, Social Media Ads"
  budget_range     String?
  tags             String[]
  priority         String   @default("Medium") // High, Medium, Low
  notes            String?
  
  stage      String @default("new_lead") // new_lead, contacted, etc.
  lead_score Int    @default(0)

  is_converted        Boolean @default(false)
  converted_client_id String?

  deal_value       Float    @default(0)

  assignee_id    String?
  next_follow_up DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company  Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  client   Client? @relation(fields: [converted_client_id], references: [id])
  assignee User?   @relation("ProspectAssignee", fields: [assignee_id], references: [id], onDelete: SetNull)

  meetings       Meeting[]
  communications CommunicationLog[]

  @@index([company_id])
  @@index([converted_client_id])
}

model Meeting {
  id           String   @id @default(uuid())
  prospect_id  String?
  project_id   String?
  title        String
  scheduled_at DateTime
  duration     Int // Minutes
  notes        String?
  created_at   DateTime @default(now())

  prospect Prospect? @relation(fields: [prospect_id], references: [id], onDelete: Cascade)
  project  Project?  @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model CommunicationLog {
  id          String   @id @default(uuid())
  company_id  String
  prospect_id String
  type        String // Email, Call, WhatsApp
  summary     String
  logged_at   DateTime @default(now())

  company  Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  prospect Prospect @relation(fields: [prospect_id], references: [id], onDelete: Cascade)
}

// --------------------------------------------------
// PROJECT ENGINE
// --------------------------------------------------

model Project {
  id         String  @id @default(uuid())
  company_id String
  client_id  String?

  project_name String
  project_ref  String?
  type         String    @default("Custom") // AI TVC, Corporate Film, etc.
  status       String    @default("draft") // draft, active, on_hold, completed, archived
  progress     Float     @default(0) // Auto-calculated
  budget       Float     @default(0)
  deadline     DateTime?
  color        String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  client  Client? @relation(fields: [client_id], references: [id])

  stages         ProjectStage[]
  milestones     Milestone[]
  objectives     Objective[]
  deliverables   Deliverable[]
  assets         Asset[]
  bookings       Booking[]
  comments       Comment[]
  expenses       Expense[]
  meetings       Meeting[]
  productionLogs ProductionLog[]
}

model ProjectStage {
  id         String    @id @default(uuid())
  project_id String
  name       String // PRE_PRODUCTION, PRODUCTION, POST_PRODUCTION, RELEASE
  order      Int
  status     String    @default("pending") // pending, active, completed
  start_date DateTime?
  end_date   DateTime?

  project    Project     @relation(fields: [project_id], references: [id], onDelete: Cascade)
  objectives Objective[]
}

model Milestone {
  id         String    @id @default(uuid())
  project_id String
  title      String
  due_date   DateTime?
  is_locked  Boolean   @default(false)
  status     String    @default("pending")

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

// --------------------------------------------------
// OBJECTIVE ENGINE (Replacing Tasks)
// --------------------------------------------------

model Objective {
  id         String  @id @default(uuid())
  project_id String
  stage_id   String?

  title       String
  description String?
  department  String?
  status      String  @default("Pending") // Pending, In Progress, In Review, Changes Requested, Approved, Completed, Blocked
  priority    String  @default("Medium") // High, Medium, Low

  assignee_id String?
  reviewer_id String?

  start_date      DateTime?
  due_date        DateTime?
  estimated_hours Float?
  actual_hours    Float     @default(0)
  completion_pct  Float     @default(0)

  checklist Json? // [{ task: "", done: false }]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  project  Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  stage    ProjectStage? @relation(fields: [stage_id], references: [id])
  assignee User?         @relation("ObjectiveAssignee", fields: [assignee_id], references: [id])
  reviewer User?         @relation("ObjectiveReviewer", fields: [reviewer_id], references: [id])

  is_blocked Boolean @default(false)

  time_entries TimeEntry[]
  comments     Comment[]
  assets       Asset[] // Linked media
  approvals    Approval[]

  // Self-referencing dependencies
  depends_on ObjectiveDependency[] @relation("ChildDependency")
  blocking   ObjectiveDependency[] @relation("ParentDependency")
}

model ObjectiveDependency {
  id        String @id @default(uuid())
  parent_id String // The objective that must be finished first
  child_id  String // The objective that is waiting
  type      String @default("blocking") // blocking, relates_to

  parent Objective @relation("ParentDependency", fields: [parent_id], references: [id], onDelete: Cascade)
  child  Objective @relation("ChildDependency", fields: [child_id], references: [id], onDelete: Cascade)

  @@unique([parent_id, child_id])
}

// --------------------------------------------------
// TIME TRACKING & RESOURCES
// --------------------------------------------------

model TimeEntry {
  id           String  @id @default(uuid())
  user_id      String
  objective_id String?

  start_time   DateTime
  end_time     DateTime?
  duration_sec Int       @default(0)
  is_billable  Boolean   @default(true)
  notes        String?

  created_at DateTime @default(now())

  user      User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  objective Objective? @relation(fields: [objective_id], references: [id], onDelete: SetNull)
}

model Resource {
  id                 String    @id @default(uuid())
  company_id         String
  name               String
  type               String
  status             String    @default("available")
  maintenance_status String    @default("good")
  created_at         DateTime  @default(now())
  bookings           Booking[]
  company            Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model Booking {
  id          String   @id @default(uuid())
  company_id  String
  resource_id String
  project_id  String
  start_date  DateTime
  end_date    DateTime
  status      String   @default("confirmed")
  created_at  DateTime @default(now())
  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  resource    Resource @relation(fields: [resource_id], references: [id], onDelete: Cascade)
}

// --------------------------------------------------
// APPROVALS, DELIVERABLES, ASSETS
// --------------------------------------------------

model Approval {
  id           String  @id @default(uuid())
  objective_id String
  requester_id String
  reviewer_id  String?

  status       String  @default("Pending") // Pending, Approved, Changes Requested
  feedback     String?
  review_round Int     @default(1)

  requested_at DateTime  @default(now())
  reviewed_at  DateTime?

  objective Objective @relation(fields: [objective_id], references: [id], onDelete: Cascade)
  requester User      @relation(fields: [requester_id], references: [id])
}

model Deliverable {
  id         String    @id @default(uuid())
  company_id String
  project_id String
  title      String
  status     String    @default("pending")
  due_date   DateTime?
  url        String?
  version    Int       @default(1)
  created_at DateTime  @default(now())

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model Asset {
  id           String  @id @default(uuid())
  company_id   String
  project_id   String
  objective_id String?

  name      String
  url       String
  file_size Int?
  file_type String?
  version   Int     @default(1)

  created_at DateTime @default(now())

  company   Company    @relation(fields: [company_id], references: [id], onDelete: Cascade)
  project   Project    @relation(fields: [project_id], references: [id], onDelete: Cascade)
  objective Objective? @relation(fields: [objective_id], references: [id], onDelete: SetNull)
}

// --------------------------------------------------
// COMMUNICATION, AUDIT & LOGS
// --------------------------------------------------

model Comment {
  id           String  @id @default(uuid())
  company_id   String
  project_id   String?
  objective_id String?
  user_id      String

  content   String
  timestamp String? // For media annotations (e.g. "01:23")

  created_at DateTime @default(now())

  company   Company    @relation(fields: [company_id], references: [id], onDelete: Cascade)
  project   Project?   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  objective Objective? @relation(fields: [objective_id], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [user_id], references: [id])
}

model Notification {
  id         String   @id @default(uuid())
  company_id String
  user_id    String
  title      String
  message    String
  type       String   @default("info") // info, alert, approval, mention
  link       String?
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id             String  @id @default(uuid())
  company_id     String
  user_id        String
  user_name      String
  action         String
  details        String?
  previous_state Json?
  new_state      Json?

  created_at DateTime @default(now())
  company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id])
}

model ProductionLog {
  id         String   @id @default(uuid())
  project_id String
  type       String // Camera Report, Audio Report, Call Sheet
  date       DateTime
  content    Json

  created_at DateTime @default(now())
  project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

// --------------------------------------------------
// FINANCE & OTHERS (Existing)
// --------------------------------------------------

model SuperAdmin {
  id         String   @id
  email      String   @unique
  granted_at DateTime @default(now())
}

model Invoice {
  id         String  @id @default(uuid())
  company_id String
  client_id  String?
  project_id String?

  invoice_number String    @unique
  total          Float
  subtotal       Float
  gst_amount     Float
  payment_status String
  issue_date     DateTime?
  due_date       DateTime?
  gst_filed      Boolean   @default(false)
  line_items     Json

  created_at DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  client  Client? @relation(fields: [client_id], references: [id])
}

model Expense {
  id         String  @id @default(uuid())
  company_id String
  project_id String?

  category    String
  description String?
  amount      Float
  date        DateTime
  account_id  String?
  status      String

  created_at DateTime @default(now())
  company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  project    Project? @relation(fields: [project_id], references: [id])
}

model GSTFiling {
  id           String   @id @default(uuid())
  company_id   String
  period       String
  gst_output   Float
  arn_number   String?
  status       String
  submitted_at DateTime @default(now())
  company      Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model Proposal {
  id              String   @id @default(uuid())
  company_id      String
  title           String
  proposal_number String?
  content         String
  status          String
  created_at      DateTime @default(now())
  company         Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model Talent {
  id              String   @id @default(uuid())
  company_id      String
  full_name       String
  category        String
  location        String?
  followers       Int      @default(0)
  engagement_rate Float    @default(0)
  is_public       Boolean  @default(true)
  portfolio_urls  String[]
  created_at      DateTime @default(now())
  company         Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model BankAccount {
  id             String   @id @default(uuid())
  company_id     String
  name           String
  type           String   @default("Bank")
  balance        Float    @default(0)
  account_number String?
  bank_name      String?
  created_at     DateTime @default(now())
  company        Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model Archive {
  id           String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  company_id   String?
  archive_type String
  archived_at  DateTime? @default(now())
  data         Json?
  created_at   DateTime? @default(now())
}

// ==========================================
// ENTERPRISE WORKFLOW ENGINE
// ==========================================

model WorkflowTemplate {
  id          String   @id @default(uuid())
  company_id  String
  name        String
  trigger     String   // e.g. "PROSPECT_WON", "MILESTONE_APPROVED"
  rules       Json     // array/object of steps & actions
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  executions WorkflowExecution[]
}

model WorkflowExecution {
  id           String   @id @default(uuid())
  template_id  String
  entity_id    String   // target ID (e.g. prospectId or clientId)
  status       String   // "running", "completed", "failed", "rolled_back"
  current_step Int      @default(0)
  context      Json     // variable storage
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  template WorkflowTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)
  logs     WorkflowExecutionLog[]
}

model WorkflowExecutionLog {
  id           String   @id @default(uuid())
  execution_id String
  step_name    String
  action_type  String
  status       String   // "success", "failed"
  error        String?
  created_at   DateTime @default(now())

  execution WorkflowExecution @relation(fields: [execution_id], references: [id], onDelete: Cascade)
}

// ==========================================
// CENTRALIZED AUDIT & ACTIVITY SYSTEM
// ==========================================

model AuditLog {
  id           String   @id @default(uuid())
  company_id   String
  user_id      String?
  action       String   // e.g. "ROLE_CHANGED", "INVOICE_APPROVED"
  entity_type  String   // e.g. "Prospect", "Invoice", "User"
  entity_id    String
  before_state Json?
  after_state  Json?
  ip_address   String?
  user_agent   String?
  created_at   DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([company_id])
  @@index([entity_type, entity_id])
}

// ==========================================
// APPROVAL ENGINE
// ==========================================

model ApprovalChain {
  id          String   @id @default(uuid())
  company_id  String
  name        String
  target_type String   // e.g. "Invoice", "Milestone"
  stages      Json     // e.g. list of stages: [{ step: 1, approver_role: "ADMIN" }]
  created_at  DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  requests ApprovalRequest[]
}

model ApprovalRequest {
  id           String   @id @default(uuid())
  chain_id     String
  company_id   String
  entity_id    String
  status       String   // "pending", "approved", "rejected", "escalated"
  current_step Int      @default(1)
  due_date     DateTime?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  chain   ApprovalChain @relation(fields: [chain_id], references: [id], onDelete: Cascade)
  company Company       @relation(fields: [company_id], references: [id], onDelete: Cascade)
  history ApprovalHistory[]
}

model ApprovalHistory {
  id          String   @id @default(uuid())
  request_id  String
  step        Int
  actor_id    String
  action      String   // "approved", "rejected", "commented"
  comment     String?
  created_at  DateTime @default(now())

  request ApprovalRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)
  actor   User            @relation(fields: [actor_id], references: [id], onDelete: Cascade)
}

// ==========================================
// CENTRALIZED NOTIFICATION QUEUE
// ==========================================

model NotificationQueue {
  id           String    @id @default(uuid())
  company_id   String
  user_id      String
  channel      String    // "IN_APP", "EMAIL", "SLACK", "WHATSAPP"
  title        String
  body         String
  priority     String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status       String    @default("queued") // queued, sent, failed
  retry_count  Int       @default(0)
  scheduled_at DateTime  @default(now())
  sent_at      DateTime?

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model NotificationPreference {
  id         String   @id @default(uuid())
  user_id    String   @unique
  channels   Json     // e.g. { "invoice_approval": ["IN_APP", "EMAIL"] }
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}


