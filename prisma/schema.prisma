generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id               String           @id @default(uuid())
  name             String
  onboardingStatus String           @default("pending")
  cin              String?
  gstin            String?
  address          String?
  bank_details     Json?
  contact_email    String?
  contact_phone    String?
  website          String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  activityLogs     ActivityLog[]
  assets           Asset[]
  bankAccounts     BankAccount[]
  comments         Comment[]
  settings         CompanySettings?
  deliverables     Deliverable[]
  expenses         Expense[]
  gstFilings       GSTFiling[]
  invoices         Invoice[]
  leads            Lead[]
  notifications    Notification[]
  projects         Project[]
  proposals        Proposal[]
  resources        Resource[]
  talents          Talent[]
  users            User[]
}

model User {
  id                String   @id
  company_id        String?
  role_id           String   @default("EMPLOYEE")
  email             String   @unique
  fullName          String
  status            String   @default("pending")
  createdAt         DateTime @default(now())
  department        String   @default("Production")
  onboarding_status String   @default("awaiting_approval")
  company           Company? @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([status])
}

model SuperAdmin {
  id         String   @id
  email      String   @unique
  granted_at DateTime @default(now())
}

model CompanySettings {
  id              String   @id @default(uuid())
  company_id      String   @unique
  modules_enabled String[]
  currency        String   @default("INR")
  timezone        String   @default("Asia/Kolkata")
  updated_at      DateTime @default(now()) @updatedAt
  theme           Json?
  company         Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
}

model Lead {
  id               String   @id @default(uuid())
  company_id       String
  company_name     String?
  email            String?
  contact_person   String?
  industry         String?
  service_vertical String?
  sub_vertical     String?
  deal_value       Float?
  stage            String?
  billing_address  String?
  gstin            String?
  created_at       DateTime @default(now())
  company          Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([stage])
}

model Project {
  id           String        @id @default(uuid())
  company_id   String
  project_name String
  project_ref  String?
  client_name  String?
  status       String
  progress     Float         @default(0)
  budget       Float         @default(0)
  deadline     DateTime?
  color        String?
  created_at   DateTime      @default(now())
  assets       Asset[]
  bookings     Booking[]
  comments     Comment[]
  deliverables Deliverable[]
  company      Company       @relation(fields: [company_id], references: [id], onDelete: Cascade)
  tasks        Task[]

  @@index([company_id])
  @@index([status])
}

model Task {
  id         String    @id @default(uuid())
  project_id String
  company_id String
  title      String
  phase      String?
  assignedTo String?
  priority   String?
  status     String    @default("pending")
  due_date   DateTime?
  created_at DateTime  @default(now())
  project    Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([project_id])
  @@index([status])
}

model Resource {
  id                 String    @id @default(uuid())
  company_id         String
  name               String
  type               String
  status             String    @default("available")
  maintenance_status String    @default("good")
  created_at         DateTime  @default(now())
  bookings           Booking[]
  company            Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
}

model Booking {
  id          String   @id @default(uuid())
  company_id  String
  resource_id String
  project_id  String
  start_date  DateTime
  end_date    DateTime
  status      String   @default("confirmed")
  created_at  DateTime @default(now())
  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  resource    Resource @relation(fields: [resource_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([resource_id])
  @@index([project_id])
}

model Asset {
  id         String   @id @default(uuid())
  company_id String
  project_id String
  name       String
  url        String
  file_size  Int?
  file_type  String?
  created_at DateTime @default(now())
  company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([project_id])
}

model Deliverable {
  id         String    @id @default(uuid())
  company_id String
  project_id String
  title      String
  status     String    @default("pending")
  due_date   DateTime?
  url        String?
  created_at DateTime  @default(now())
  company    Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  project    Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([project_id])
}

model Comment {
  id         String   @id @default(uuid())
  company_id String
  project_id String
  user_id    String
  user_name  String
  content    String
  created_at DateTime @default(now())
  company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([project_id])
}

model Notification {
  id         String   @id @default(uuid())
  company_id String
  user_id    String
  title      String
  message    String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([user_id])
}

model ActivityLog {
  id         String   @id @default(uuid())
  company_id String
  user_id    String
  user_name  String
  action     String
  details    String?
  created_at DateTime @default(now())
  company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([created_at])
}

model Invoice {
  id             String    @id @default(uuid())
  company_id     String
  client_name    String?
  client_id      String?
  project_id     String?
  project_name   String?
  project_ref    String?
  invoice_number String    @unique
  total          Float
  subtotal       Float
  gst_amount     Float
  payment_status String
  issue_date     DateTime?
  due_date       DateTime?
  gst_filed      Boolean   @default(false)
  line_items     Json
  created_at     DateTime  @default(now())
  company        Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([payment_status])
}

model GSTFiling {
  id           String   @id @default(uuid())
  company_id   String
  period       String
  gst_output   Float
  arn_number   String?
  status       String
  submitted_at DateTime @default(now())
  company      Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
}

model Expense {
  id          String   @id @default(uuid())
  company_id  String
  project_id  String?
  category    String
  description String?
  amount      Float
  date        DateTime
  account_id  String?
  status      String
  created_at  DateTime @default(now())
  company     Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([project_id])
}

model Proposal {
  id              String   @id @default(uuid())
  company_id      String
  lead_id         String?
  title           String
  client_name     String?
  proposal_number String?
  content         String
  status          String
  created_at      DateTime @default(now())
  company         Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
  @@index([status])
}

model Talent {
  id              String   @id @default(uuid())
  company_id      String
  full_name       String
  category        String
  location        String?
  followers       Int      @default(0)
  engagement_rate Float    @default(0)
  is_public       Boolean  @default(true)
  portfolio_urls  String[]
  created_at      DateTime @default(now())
  company         Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
}

model BankAccount {
  id             String   @id @default(uuid())
  company_id     String
  name           String
  type           String   @default("Bank")
  balance        Float    @default(0)
  account_number String?
  bank_name      String?
  created_at     DateTime @default(now())
  company        Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id])
}

model Archive {
  id               String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  company_id       String?
  archive_type     String
  archived_at      DateTime? @default(now())
  company_name     String?
  industry         String?
  email            String?
  contact_person   String?
  service_vertical String?
  sub_vertical     String?
  project_name     String?
  client_name      String?
  budget           Decimal?
  status           String?
  deadline         String?
  color            String?
  progress         Int?
  notes            String?
  created_at       DateTime? @default(now())

  @@index([company_id])
}
