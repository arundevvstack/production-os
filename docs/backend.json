
{
  "entities": {
    "Company": {
      "title": "Company",
      "type": "object",
      "description": "Represents a single company (tenant) within the multi-tenant SaaS platform.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "onboardingStatus": { "type": "string" },
        "cin": { "type": "string", "description": "Corporate Identification Number" },
        "gstin": { "type": "string", "description": "GST Identification Number" },
        "address": { "type": "string" },
        "bank_details": {
          "type": "object",
          "properties": {
            "bank_name": { "type": "string" },
            "account_no": { "type": "string" },
            "ifsc": { "type": "string" },
            "branch": { "type": "string" },
            "pan": { "type": "string" }
          }
        },
        "contact_email": { "type": "string" },
        "contact_phone": { "type": "string" },
        "website": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "onboardingStatus", "createdAt"]
    },
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user account within a specific company.",
      "properties": {
        "id": { "type": "string" },
        "company_id": { "type": "string" },
        "role_id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "company_id", "role_id", "email", "fullName", "status", "createdAt"]
    },
    "Lead": {
      "title": "Lead",
      "type": "object",
      "description": "Represents a potential client or sales opportunity.",
      "properties": {
        "id": { "type": "string" },
        "company_id": { "type": "string" },
        "company_name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "contact_person": { "type": "string", "description": "Primary liaison for the client." },
        "industry": { "type": "string" },
        "service_vertical": { "type": "string" },
        "sub_vertical": { "type": "string" },
        "deal_value": { "type": "number" },
        "stage": { "type": "string" },
        "billing_address": { "type": "string" },
        "gstin": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "Project": {
      "title": "Project",
      "type": "object",
      "description": "Represents a media production workspace.",
      "properties": {
        "id": { "type": "string" },
        "company_id": { "type": "string" },
        "project_name": { "type": "string" },
        "project_ref": { "type": "string", "description": "Internal reference code like MRZL_202604_GG11" },
        "client_name": { "type": "string" },
        "status": { "type": "string" },
        "progress": { "type": "number" },
        "budget": { "type": "number" },
        "deadline": { "type": "string" },
        "color": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "description": "Represents a financial billing record.",
      "properties": {
        "id": { "type": "string" },
        "company_id": { "type": "string" },
        "client_name": { "type": "string" },
        "client_id": { "type": "string" },
        "project_id": { "type": "string" },
        "project_name": { "type": "string" },
        "project_ref": { "type": "string" },
        "invoice_number": { "type": "string" },
        "total": { "type": "number" },
        "subtotal": { "type": "number" },
        "gst_amount": { "type": "number" },
        "payment_status": { "type": "string" },
        "issue_date": { "type": "string" },
        "due_date": { "type": "string" },
        "gst_filed": { "type": "boolean" },
        "line_items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "unit_price": { "type": "number" },
              "quantity": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "GSTFiling": {
      "title": "GSTFiling",
      "type": "object",
      "description": "Represents an automated GST submission record.",
      "properties": {
        "id": { "type": "string" },
        "company_id": { "type": "string" },
        "period": { "type": "string" },
        "gst_output": { "type": "number" },
        "arn_number": { "type": "string" },
        "status": { "type": "string" },
        "submitted_at": { "type": "string", "format": "date-time" }
      }
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "description": "Represents a company expense (running costs, salary, etc.).",
      "properties": {
        "id": { "type": "string" },
        "company_id": { "type": "string" },
        "project_id": { "type": "string", "description": "Optional project link for P&L tracking." },
        "category": { "type": "string", "enum": ["Salary", "Rent", "Utilities", "Production", "Marketing", "Other"] },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "account_id": { "type": "string" },
        "status": { "type": "string", "enum": ["Paid", "Pending"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "company_id", "category", "amount", "date"]
    },
    "Proposal": {
      "title": "Proposal",
      "type": "object",
      "description": "Represents a high-premium sales production blueprint.",
      "properties": {
        "id": { "type": "string" },
        "company_id": { "type": "string" },
        "lead_id": { "type": "string" },
        "title": { "type": "string" },
        "client_name": { "type": "string" },
        "proposal_number": { "type": "string" },
        "content": { "type": "string", "description": "Structured JSON blueprint stringified." },
        "status": { "type": "string", "enum": ["draft", "sent", "accepted", "rejected"] },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "super_admins/{userId}": {
      "schema": {
        "type": "object",
        "properties": {
          "uid": { "type": "string" },
          "email": { "type": "string" },
          "granted_at": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Platform-wide super administrators."
    },
    "users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles and workspace affiliation."
    },
    "companies/{companyId}": {
      "schema": { "$ref": "#/backend/entities/Company" },
      "description": "Multi-tenant company roots."
    },
    "companies/{companyId}/leads/{leadId}": {
      "schema": { "$ref": "#/backend/entities/Lead" },
      "description": "Sales opportunities and client relations."
    },
    "companies/{companyId}/projects/{projectId}": {
      "schema": { "$ref": "#/backend/entities/Project" },
      "description": "Production workspaces."
    },
    "companies/{companyId}/invoices/{invoiceId}": {
      "schema": { "$ref": "#/backend/entities/Invoice" },
      "description": "Billing records."
    },
    "companies/{companyId}/gst_filings/{filingId}": {
      "schema": { "$ref": "#/backend/entities/GSTFiling" },
      "description": "Statutory submission history."
    },
    "companies/{companyId}/expenses/{expenseId}": {
      "schema": { "$ref": "#/backend/entities/Expense" },
      "description": "Running costs and payroll."
    },
    "companies/{companyId}/proposals/{proposalId}": {
      "schema": { "$ref": "#/backend/entities/Proposal" },
      "description": "AI-Architected high-premium pitch blueprints."
    }
  }
}
